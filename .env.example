# =============================================================================
# Imperium — Environment Variables (template)
#
# Copy this file to `.env` and fill in your values:
#     cp .env.example .env
#
# Anything prefixed with VITE_ is exposed to the browser at build time.
# Everything else is server-only (server functions and SSR).
# Never commit `.env` to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Supabase (REQUIRED — database, auth, storage)
#
# Use Lovable Cloud, a hosted supabase.com project, or a self-hosted Supabase
# stack. All three work identically — the app only needs the URL + keys.
#
# Get these from:  Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------

# Browser-visible (publishable):
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# Server-only mirrors of the same values (used by SSR and server functions):
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Service-role key — NEVER expose to the browser. Used by admin operations
# in server functions and migrations.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."

# Optional, only needed if you run scripts that connect directly to Postgres:
# SUPABASE_DB_URL="postgres://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# 2. AI provider (REQUIRED — at least ONE of the following)
#
# The Brain (resume scoring, ATS analysis, cover letters, job matching)
# automatically fails over across whichever providers you configure, in this
# order: OpenRouter → OpenAI → Anthropic → Lovable AI Gateway.
#
# Recommended default: OpenRouter (single key, access to most models).
# -----------------------------------------------------------------------------

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# OpenAI direct — https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Anthropic direct — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# Lovable AI Gateway — auto-provisioned only when running on Lovable Cloud.
# Leave blank for self-hosted deployments.
LOVABLE_API_KEY=""

# -----------------------------------------------------------------------------
# 3. App configuration (OPTIONAL)
# -----------------------------------------------------------------------------

# Public URL of your deployment. Used in OpenRouter request headers and
# any outbound link generation. Defaults to http://localhost:3000.
PUBLIC_APP_URL="http://localhost:3000"

# Node environment. Vite reads this automatically — usually you don't set it.
# NODE_ENV="development"

# -----------------------------------------------------------------------------
# 4. Local Agent bridge (OPTIONAL — only if you run IMPERIUM/local_agent)
# -----------------------------------------------------------------------------

# URL of the local Selenium agent (Python). Default: http://127.0.0.1:8000
# The local agent is loopback-only and runs without authentication.
VITE_LOCAL_AGENT_URL="http://127.0.0.1:8000"

