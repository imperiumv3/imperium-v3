# Local Imperium agent — fully offline. No Supabase, no tokens, no cloud.
HOST=127.0.0.1
PORT=8000
HEADLESS=0
# Optional: where to persist run state across restarts
STATE_FILE=./agent_state.json

# ---- Chrome profile ----------------------------------------------------
# Default: dedicated persistent profile at ~/.imperium_chrome_profile
# Set USE_REAL_CHROME=1 to reuse your everyday Chrome User Data folder.
USE_REAL_CHROME=0
CHROME_USER_DATA_DIR=
CHROME_PROFILE_DIR=Default

# ---- Local LLM brain (Ollama) ------------------------------------------
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=30

# Optional: path to your resume PDF for auto-upload.
# RESUME_PATH=C:\Users\dinesh\Documents\resume.pdf
