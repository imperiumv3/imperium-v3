# Local Imperium agent — fully offline. No Supabase, no tokens, no cloud.
HOST=127.0.0.1
PORT=8000
HEADLESS=0

# ---- Chrome profile ----------------------------------------------------
# Default: dedicated persistent profile at ~/.imperium_chrome_profile
# Set USE_REAL_CHROME=1 to reuse your everyday Chrome User Data folder.
USE_REAL_CHROME=0
CHROME_USER_DATA_DIR=
CHROME_PROFILE_DIR=Default
# Optional: force a specific Chrome major version (e.g. 126, 127)
# CHROME_VERSION_MAIN=

# ---- Local LLM brain (Ollama) ------------------------------------------
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=30

# ---- Resume -------------------------------------------------------------
# Optional: path to your resume PDF for auto-upload.
# RESUME_PATH=C:\Users\dinesh\Documents\resume.pdf

# ---- Agent behavior -----------------------------------------------------
# Where to persist run state across restarts
STATE_FILE=./storage/application_history.json
# Max concurrent browser automation sessions (default: 1)
MAX_CONCURRENT_RUNS=1
# Timeout waiting for human approval in seconds (default: 600)
APPROVAL_TIMEOUT=600
# Page load timeout in seconds (default: 20)
PAGE_LOAD_TIMEOUT=20
# Max wizard steps for multi-step forms (default: 20)
MAX_WIZARD_STEPS=20
# Retry settings
MAX_RETRIES=3
