# ============================================================
# Imperium — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- LLM (optional — heuristic fallback used if not set) ---
IMPERIUM_LLM_API_KEY=sk-...
OPENAI_API_KEY=sk-...          # alias for IMPERIUM_LLM_API_KEY
IMPERIUM_LLM_MODEL=gpt-4o-mini
IMPERIUM_LLM_BASE_URL=https://api.openai.com/v1
IMPERIUM_LLM_TIMEOUT_SECONDS=45
IMPERIUM_LLM_TEMPERATURE=0.2
IMPERIUM_LLM_CONCURRENCY=3

# --- Job Discovery APIs (optional — free sources used if not set) ---
ADZUNA_APP_ID=
ADZUNA_API_KEY=
RAPIDAPI_KEY=
JSEARCH_API_KEY=

# --- Database paths (optional — defaults to imperium/agents/job_agent/data/) ---
IMPERIUM_JOB_AGENT_DB=
IMPERIUM_CAREER_MEMORY_DB=

# --- Application limits ---
IMPERIUM_DAILY_APP_LIMIT=20
IMPERIUM_MIN_MATCH_THRESHOLD=0.72
IMPERIUM_SCAN_INTERVAL_HOURS=6

# --- Server ---
IMPERIUM_HOST=0.0.0.0
IMPERIUM_PORT=8000
IMPERIUM_RELOAD=true
